# Recommended: Google AI Studio API key (free, generous limits)
# Get your free key from https://aistudio.google.com/apikey
GOOGLE_AI_KEY=

# Get your free API key from https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_your_token_here

# Optional: Port (default 8000)
PORT=8000

# Optional: Groq API key (free LLM fallback) — https://console.groq.com
GROQ_API_KEY=

# Optional: Resend API key for sending daily digest emails
# Get your free key from https://resend.com
RESEND_API_KEY=

