# DailyAI v2 — Environment Variables

# ── Server ────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
DEBUG=false
APP_URL=http://localhost:8000
APP_VERSION=2.0.0

# ── Cache / Refresh Behavior ──────────────────────────────────────
# Total rotating DB cache limit (across all country/language keys)
CACHE_MAX_ARTICLES=100
# Keep at least this many articles per key when pruning cache
CACHE_MIN_PER_KEY=8
# Startup prefetch target sizes
STARTUP_PREFETCH_GLOBAL_LIMIT=30
STARTUP_PREFETCH_OTHER_LIMIT=18
# Daily full cache refresh schedule (UTC)
DAILY_REFRESH_HOUR_UTC=6
DAILY_REFRESH_MINUTE_UTC=0

# ── Database ──────────────────────────────────────────────────────
DB_PATH=dailyai.db
# Storage backend: sqlite (default) or supabase
STORAGE_BACKEND=sqlite
# (Optional) Supabase credentials for cloud sync if needed
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_TIMEOUT_SECONDS=10

# ── LLM Providers (Set at least ONE) ─────────────────────────────
# Primary provider is ARLIAI when configured (OpenAI-compatible API)
ARLIAI_API_KEY=
ARLIAI_MODEL=Qwen3.5-27B-Anko
ARLIAI_BASE_URL=https://api.arliai.com/v1

# Fallback 1: Gemini
GOOGLE_AI_KEY=

# Fallback 2: Groq (fastest)
GROQ_API_KEY=

# Fallback 3: NVIDIA / DeepSeek
NVIDIA_API_KEY=

# Fallback 4: HuggingFace Serverless
HF_API_TOKEN=

# Fallback 5: Local Ollama
OLLAMA_BASE_URL=
OLLAMA_MODELS=llama3.1:8b

# ── Email Digest via Resend (Optional) ────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=DailyAI <onboarding@resend.dev>
RESEND_REPLY_TO=

# ── Analytics (Optional) ──────────────────────────────────────────
# Umami Website Tracking
UMAMI_WEBSITE_ID=
# If self-hosting, change this to your custom umami script URL
UMAMI_URL=https://analytics.umami.is/script.js