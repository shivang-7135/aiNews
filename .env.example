# DailyAI v2 — Environment Variables

# ── Server ────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
DEBUG=false
APP_URL=http://localhost:8000
APP_VERSION=2.0.0

# ── Database ──────────────────────────────────────────────────────
DB_PATH=dailyai.db
# (Optional) Supabase credentials for cloud sync if needed
SUPABASE_URL=
SUPABASE_KEY=

# ── LLM Providers (Set at least ONE) ─────────────────────────────
# Primary provider for v2 is Gemini (best free tier + quality)
GOOGLE_AI_KEY=your_gemini_key_here

# Fallback 1: Groq (fastest)
GROQ_API_KEY=

# Fallback 2: NVIDIA / DeepSeek
NVIDIA_API_KEY=

# Fallback 3: HuggingFace Serverless
HF_API_TOKEN=

# Fallback 4: Local Ollama
OLLAMA_BASE_URL=
OLLAMA_MODELS=llama3.1:8b

# ── Email Digest via Resend (Optional) ────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=DailyAI <onboarding@resend.dev>
RESEND_REPLY_TO=